{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "railcross-ai",
  // Must not exceed the newest date supported by the installed workerd binary,
  // or `npm run dev` fails with ERR_RUNTIME_FAILURE.
  "compatibility_date": "2026-05-22",
  "main": "./worker/index.ts",
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  }
}
